{
  "name": "allinonesocials",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first desktop social media manager powered by Electron, React, and Playwright automation.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "pack": "npm run build && electron-builder --dir --publish never",
    "dist:win": "npm run build && electron-builder --win nsis --publish never",
    "dist:win:portable": "npm run build && electron-builder --win portable --publish never"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shariqsk/allinonesocials.git"
  },
  "keywords": [
    "electron",
    "react",
    "playwright",
    "social-media"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/shariqsk/allinonesocials/issues"
  },
  "homepage": "https://github.com/shariqsk/allinonesocials#readme",
  "build": {
    "appId": "com.socialdesk.desktop",
    "productName": "Social Desk",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "asar": true,
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "SocialDesk-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Social Desk"
    },
    "portable": {
      "artifactName": "SocialDesk-Portable-${version}.${ext}"
    }
  },
  "dependencies": {
    "dayjs": "^1.11.20",
    "electron-log": "^5.4.3",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.6.0",
    "sql.js": "^1.14.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sql.js": "^1.4.10",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.0"
  }
}
